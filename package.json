{
  "name": "pi-mcp-codemode",
  "version": "0.1.0",
  "description": "Typed, sandboxed Code Mode access to configured MCP servers for Pi",
  "type": "module",
  "private": true,
  "license": "MIT",
  "keywords": [
    "pi-package",
    "mcp",
    "code-mode"
  ],
  "files": [
    "extensions",
    "src",
    "sidecar",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun run test:ts && bun run test:python",
    "test:ts": "bun test tests/typescript",
    "test:python": "uv run --project sidecar --frozen pytest tests/python -q",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@types/bun": "latest",
    "typebox": "1.3.6",
    "typescript": "5.9.3"
  }
}
