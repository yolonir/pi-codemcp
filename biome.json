{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "files": {
    "includes": [
      "extensions/**/*.ts",
      "src/**/*.ts",
      "tests/**/*.ts",
      "*.json",
      ".release-please-manifest.json"
    ]
  }
}
