{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "noEmit": true,
    "types": ["bun"]
  },
  "include": ["extensions/**/*.ts", "src/**/*.ts", "tests/typescript/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
